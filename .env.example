SECRET_KEY=your-secret-key-here-min-32-chars-with-upper-lower-number-special!
#DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=60
DEBUG=false

# Redis broker for TaskIQ email tasks and rate limiting
REDIS_URL=redis://localhost:6379
USE_REDIS_BROKER=true

# AWS S3 / Cloudflare R2 Storage
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=auto
STORAGE_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
STORAGE_BASE_URL=https://your-cdn-domain.com

# OTP settings
OTP_EXPIRY_SECONDS=90
RATE_LIMIT_OTP_MAX=3
RATE_LIMIT_OTP_WINDOW_SECONDS=600

# SMS provider (set SMS_PROVIDER_ENABLED=true and implement utils/sms.py to go live)
SMS_PROVIDER_ENABLED=false

# Paylink.sa payment gateway
PAYLINK_API_ID=your-paylink-api-id
PAYLINK_API_KEY=your-paylink-api-key
PAYLINK_TEST_MODE=true
PAYLINK_CALLBACK_URL=https://your-domain.com/payments/paylink-callback
PAYLINK_RETURN_URL=https://your-domain.com/payments/return
PAYLINK_CALLBACK_RATE_LIMIT_PER_MINUTE=10

# Email provider: smtp | sender_net | sendgrid | mailgun
EMAIL_PROVIDER=smtp
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM_ADDRESS=noreply@your-domain.com
EMAIL_FROM_NAME=Giftly
EMAIL_API_KEY=your-email-provider-api-key

# CORS — comma-separated list of allowed frontend origins (never use * in production)
ALLOWED_ORIGINS=["https://app.your-domain.com","https://admin.your-domain.com"]

# Security headers
HSTS_MAX_AGE_SECONDS=31536000

# Chat message limits (override to relax/tighten per deployment)
CHAT_MSG_MAX_CHARS=300
CHAT_IMAGE_MAX_BYTES=6291456
CHAT_VIDEO_MAX_BYTES=73400320
CHAT_VIDEO_MAX_SECS=30

# Wallet charge limits
WALLET_CHARGE_MIN_SAR=10
WALLET_CHARGE_MAX_SAR=100

# Admin wallet charge cap (halalas; 1 SAR = 100)
ADMIN_WALLET_CHARGE_MAX_HALALAS=1000000

# WebSocket max raw payload size (bytes)
WS_MAX_PAYLOAD_BYTES=65536
